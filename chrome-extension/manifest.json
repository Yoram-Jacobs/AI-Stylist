{
  "manifest_version": 3,
  "name": "DressApp Shopping Assistant",
  "short_name": "DressApp",
  "description": "Real-time size recommendations on Zara, ASOS, Shein, H&M, Amazon, AliExpress and more — powered by your DressApp measurements.",
  "version": "0.1.0",
  "action": {
    "default_title": "DressApp Shopping Assistant",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.zara.com/*",
        "https://*.asos.com/*",
        "https://*.shein.com/*",
        "https://*.hm.com/*",
        "https://*.amazon.com/*",
        "https://*.amazon.co.uk/*",
        "https://*.amazon.de/*",
        "https://*.amazon.fr/*",
        "https://*.amazon.it/*",
        "https://*.amazon.es/*",
        "https://*.aliexpress.com/*",
        "https://*.aliexpress.us/*"
      ],
      "js": ["src/content/content.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://dressapp.co/extension/connect*",
        "https://*.dressapp.co/extension/connect*",
        "https://*.preview.emergentagent.com/extension/connect*"
      ],
      "js": ["src/content/auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://dressapp.co/*",
    "https://*.dressapp.co/*",
    "https://*.preview.emergentagent.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://dressapp.co/*",
      "https://*.dressapp.co/*",
      "https://*.preview.emergentagent.com/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
