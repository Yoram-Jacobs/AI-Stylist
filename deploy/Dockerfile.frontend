# Frontend Dockerfile — DressApp SPA
#
# Multi-stage build: compiles the CRA/craco bundle with a baked-in
# REACT_APP_BACKEND_URL (which is same-origin since Caddy terminates
# `/api/*` on the same domain), then serves the static bundle on :3000
# via a tiny nginx.
#
# Build:
#   docker build -f deploy/Dockerfile.frontend \
#     --build-arg REACT_APP_BACKEND_URL=https://dressapp.co \
#     -t dressapp-frontend:latest .

FROM node:20-bookworm-slim AS builder

WORKDIR /app

# Build-time env var — baked into the bundle. For same-domain deploys
# this is the full public URL; CRA expects it with scheme + host.
ARG REACT_APP_BACKEND_URL=""
ENV REACT_APP_BACKEND_URL=${REACT_APP_BACKEND_URL}
# Disable CRA source-maps in the final bundle to shave ~30 % off size.
ENV GENERATE_SOURCEMAP=false
# Tell CRA not to fail on lint warnings (treat warnings as warnings only).
ENV CI=false

# Copy the manifest first so Docker caches the yarn-install layer.
COPY frontend/package.json frontend/yarn.lock ./
RUN yarn install --frozen-lockfile --network-timeout 600000

COPY frontend/ ./
RUN yarn build

# --- Runtime stage ---------------------------------------------------
FROM nginx:1.27-alpine AS runtime

# Non-root static server with a SPA-friendly config (history fallback).
COPY deploy/nginx-frontend.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/build /usr/share/nginx/html

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
